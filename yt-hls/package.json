{
  "name": "yt-hls",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal local HLS gateway: YouTube video id in → playable .m3u8 out (SABR remuxed to HLS on the fly).",
  "bin": {
    "yt-hls": "server.mjs"
  },
  "scripts": {
    "start": "node server.mjs",
    "postinstall": "node scripts/patch_googlevideo.mjs"
  },
  "dependencies": {
    "bgutils-js": "^3.2.0",
    "googlevideo": "^4.0.4",
    "jsdom": "^29.1.1",
    "youtubei.js": "^17.0.1"
  }
}
